<div component-name="@nameof(SliderNumberInput)"
        class=@this.AddedClasses
        style="@this.AddedStyles border: 1px; display: flex; align-items: center; max-width: 100%;">
    @* step=    this.Step *@
    <input type="range"
            min=@this.Min
            max=@this.Max
            value=@this.Value
            style="flex-grow: 1; min-width: 50px;"
            @onchange=@this.OnInput_UI_Async />
    <input type="number"
            min=@this.Min
            max=@this.Max
            value=@this.Value
            style="flex-shrink: 0; width: 55px;"
            @onchange=@this.OnInput_UI_Async />
</div>



@code {
    private async Task OnInput_UI_Async( ChangeEventArgs e ) {
        if( e.Value is null ) {
            return;
        }

        if( !double.TryParse(e.Value.ToString(), out double newValue) ) {
            return;
        }

        this.Value = newValue;

        if( this.OnValueChanged_Async is not null ) {
            await this.OnValueChanged_Async.Invoke( newValue );
        }
    }
}
