@if( this.IsVisible ) {
    <div class="tooltip-content" style="top: @(this.Y)px; left: @(this.X)px;">
    @* <div class="tooltip-content" style="transform: translate3d(@(this.Y)px; @(this.X)px, 0);"> *@
        @this.TooltipContent
    </div>
}
<div @onmouseover=@this.ShowTooltip
            @onmouseout=@this.HideTooltip
            style="display: inline-block;">
    @this.Anchor
</div>



@code {
    [Parameter]
    public RenderFragment Anchor { get; set; } = null!;
    
    [Parameter]
    public RenderFragment TooltipContent { get; set; } = null!;

    [Parameter]
    public Func<bool>? Enabled { get; set; }
    

    private bool IsVisible { get; set; }

    private double X { get; set; }

    private double Y { get; set; }



    private void ShowTooltip( MouseEventArgs e ) {
        // Calculate dynamic coordinates relative to the mouse or offset
        this.X = e.ClientX + 12; 
        this.Y = e.ClientY + 12;
        if( this.Enabled?.Invoke() ?? true ) {
            this.IsVisible = true;
        }
    }

    private void HideTooltip() {
        this.IsVisible = false;
    }
}

