@using Microsoft.AspNetCore.Components;
@using MindCabinet.Client.Components.Application.Editors;
@using MindCabinet.Client.Components.Application.Renders;
@using MindCabinet.Client.Components.Standard;
@using MindCabinet.Client.Services;
@using MindCabinet.Shared.DataObjects;
@using MindCabinet.Shared.DataObjects.PostsContext;
@using MindCabinet.Shared.DataObjects.Term;
@using System.Text.Json



<div component-name="PostsContextEditor" class=@this.AddedClasses>
	<Tooltip>
		<Anchor><h4>Context name:</h4></Anchor>
		<TooltipContent>AKA an arbitrary circumstance or phenomenon to be described</TooltipContent>
	</Tooltip>
	<input type="text"
			placeholder="Enter context name"
			@bind:event="oninput"
            @bind:get=@this.EditContext_Name
            @bind:set=@this.OnInputName_UI_Async />
	<h4>Enter tags to describe your current "context":</h4>
	<TermSetEditor Label="Enter tags (at least 1 required)"
			AddedPerItemClasses="d-block"
			InitialTerms=@( this.EditContext_Entries
				.Select( e => e.Term )
				.ToList() )
			VerboseTermDisplay=@true
			AllowFavoritingTerms=@false
			OnTermsChange_Async=@this.OnTagsChanged_UI_Async>
		<PerTermAffix Context="termOfSet">
			<SliderNumberInput
					InitialValue=@(this.GetTagPriorityValue(termOfSet) ?? 0)
					OnValueChanged_Async=@( async (val) => await this.OnPriorityChange_UI_Async(termOfSet, val) ) />
			<div style="float: right;">
				<label for="isreq_@(termOfSet.ToId(verbose: true))">Is required</label>
				<input type="checkbox"
						name="isreq_@(termOfSet.ToId(verbose: true))"
						checked=@this.GetFirstMatchingTagEntry(termOfSet.Id).IsRequired
						@onchange=@( async (e) => await this.OnIsRequiredChange_UI_Async(termOfSet, (bool)e.Value!) ) />
			</div>
		</PerTermAffix>
	</TermSetEditor>
	<div>
		<div>Context options:</div>
		<button @onclick=@(() => this.ClearEditContext_UI(false))>
			Create New
		</button>
		<button disabled=@( !this.CanSaveEdits(this.DefaultContext is null) )
				@onclick=@this.SaveContext_UI_Async>
			Save Changes
		</button>
	</div>
</div>


<RenderPortal TargetRegion="ModalDialogs">
	<Modal @ref=@this.ConfirmResetPrompt_DialogComponent
			ModalId=@this.ConfirmResetPrompt_ModalDialogId
			Title="Confirm Context Creation">
		<BodyContent>
			<i>You have unsaved changes. Remove all changes?</i>
			<div>
				<button @onclick=@(this.ConfirmResetPrompt_DialogComponent.Close)>
					Cancel
				</button>
				<button @onclick=@( () => this.ClearEditContext_UI(true))>
					Confirm
				</button>
			</div>
		</BodyContent>
	</Modal>
</RenderPortal>



@code {
    private string ConfirmResetPrompt_ModalDialogId => "PostsContextEditor_Reset_" + Guid.NewGuid()
        .ToString("N")
        .Substring(0, 8);


    private Modal ConfirmResetPrompt_DialogComponent = null!;



	private double? GetTagPriorityValue( TermObject tag ) {
		return this.EditContext_Entries
			.FirstOrDefault( t => t.Term.Id == tag.Id )?
			.Priority;
	}

	private PostsContextTermEntryObject GetFirstMatchingTagEntry( TermId id ) {
		try {
			return this.EditContext_Entries
				.First( t => t.Term.Id == id );
		} catch( InvalidOperationException e ) {
			IEnumerable<TermId> entryIds = this.EditContext_Entries
				.Select( e => e.Term.Id );

			throw new InvalidOperationException( $"Expecting: {id}, Found: {entryIds}", e );
		}
	}

	
    private async Task OnInputName_UI_Async( string? nameText ) {
        await Task.CompletedTask;
		
        if( string.IsNullOrEmpty(nameText) ) {
            return;
        }

		this.EditContext_Name = nameText;
    }

	private async Task OnTagsChanged_UI_Async(
				IEnumerable<TermObject> currentTags,
				TermObject changedTag,
				bool isAdded ) {
		PostsContextTermEntryObject? changedTagEntry = null;

		if( isAdded ) {
			changedTagEntry = this.AddNewTag( changedTag );
		} else {
			changedTagEntry = this.RemoveTag( changedTag );
		}

        if( this.OnEntryEdit_Async is not null && changedTagEntry is not null ) {
            await this.OnEntryEdit_Async.Invoke( changedTagEntry, isAdded );
        }

		this.StateHasChanged();
	}
	
	private async Task OnPriorityChange_UI_Async( TermObject tag, double newValue ) {
        await Task.CompletedTask;

		PostsContextTermEntryObject? entry = this.EditContext_Entries
			.First( t => t.Term.Id == tag.Id );

		entry.SetPriority( newValue );

		this.StateHasChanged();
	}
	
	private async Task OnIsRequiredChange_UI_Async( TermObject tag, bool newValue ) {
        await Task.CompletedTask;

		PostsContextTermEntryObject? entry = this.EditContext_Entries
			.First( t => t.Term.Id == tag.Id );

		entry.SetIsRequired( newValue );

		this.StateHasChanged();
	}

	private void ClearEditContext_UI( bool forceReset ) {
		if( this.HasUnsavedChanges() && !forceReset ) {
			this.ConfirmResetPrompt_DialogComponent.Open();

			return;
		}

		// if( this.ResetPromptDialog.IsOpen ) {
		this.ConfirmResetPrompt_DialogComponent.Close();

		this.ClearEditContext();

		this.StateHasChanged();
	}


	private async Task SaveContext_UI_Async() {
		await this.UpdateOrCreate_Async();
        
		this.StateHasChanged();
    }
}
