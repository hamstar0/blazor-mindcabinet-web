@using MindCabinet.Shared.DataObjects;
@using MindCabinet.Shared.DataObjects.Term;
@using MindCabinet.Shared.DataObjects.UserPostsContext



<div component-name="MultiUserPostsContextRender"
        class="basic @(this.AddedClasses ?? "")"
        style="background-color: white;"
        @onfocusin=@(e => this.HasFocus = true)
        @onfocusout=@(e => this.HasFocus = false)>
    @foreach( UserPostsContextObject context in this.Contexts ) {
        <UserPostsContextRender
                AddedClasses="ib"
                Context=@context
                OnClick_Async=@(async e => await this.OnClickEach_UI_Async(context, e)) />
    }
</div>



@code {
    private async Task OnClickEach_UI_Async( UserPostsContextObject context, MouseEventArgs args ) {
        if( this.OnClick_Async is not null ) {
            //this.HasFocus = await this.OnClickEach_Async( term, args );
            await this.OnClick_Async( context, args );
        }
    }
}